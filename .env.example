# Copy to .env and fill in the values. The .env file is gitignored.
# Loaded by evals/translate.eval.ts and evals/harvest.eval.ts via loadDotenv().

# Required for `npm run eval` and `npm run eval:harvest`.
GEMINI_API_KEY=

# Optional. Selects which datasets the eval suite runs.
#   smoke = subset for fast feedback
#   full  = every dataset under evals/data/ (default)
# EVAL_SUITE=full

# Optional. Pass threshold for the suite as a fraction in (0, 1]. Default 0.9.
# EVAL_THRESHOLD=0.9
